Algoritmo operaciones 
	definir n1,n2,n3,n4, n5 ,r como entero 
	
	escribir "ingresa el primer numero" 
	leer n1
	
	escribir " ingresa el segundo numero "
	leer n2 
	
	escribir " ingrsa el tercer numero" 
	leer n3 
	
	escribir "ingresa el cuarto numero "
	leer n4
	escribir " ingrsa el quinto numero " 
	leer n5
	
	r=n1+n2-n3*n4/n5
	
	escribir " el resultado es ", r 
	
	
	
